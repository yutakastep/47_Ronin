theme_override_font_sizes/normal_font_size = 9
bbcode_enabled = true
text = "The year is 1703, and you are a master-less samurai known as a Ronin. Your master has been forced to death due to the actions of one [color=red]Kira Yoshinaka[/color], who was never punished. You and your 46 peers all vowed to avenge your master by killing this man. After two years of plotting, your plan came to fruition and you stormed the [color=red]Yoshinaka[/color] castle. Despite your best efforts, you failed and the [color=orange]47[/color] of you met your end within his castle walls. In your dying moments, you are visited by a [color=aqua]kappa,[/color] a trickster spirit. He offers you a choice: another shot at revenge in exchange for you and your men's souls. [color=white]This is your story.[/color]"
horizontal_alignment = 1
